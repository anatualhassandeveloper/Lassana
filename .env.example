# Site URL used for SEO metadata, sitemap, and Open Graph tags.
# Set this to your production domain when deploying (e.g. Vercel).
NEXT_PUBLIC_SITE_URL=https://www.lassanamachinery.com

# Google Search Console — HTML tag verification (easier than DNS TXT).
# Search Console → Settings → Ownership verification → HTML tag → copy the content value only.
# Example: if the tag is content="abc123", set GOOGLE_SITE_VERIFICATION=abc123
GOOGLE_SITE_VERIFICATION=
